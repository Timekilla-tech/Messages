  namespace MODIFIED_MessagesDB {
    class MessagesDatabase {
      <<MODIFIED version 11→12>>
      %% ── NEW ──
      + CategoryDao() CategoryDao
      %% MIGRATION_10_11: categories table, category cols on messages+conversations
      %% MIGRATION_11_12: keywords_is_regex column
    }
  }

  namespace MODIFIED_Config {
    class Config {
      <<MODIFIED - SavedViews + swipe actions>>
      %% ── NEW fields ──
      + savedViewsJson : String
      + lastSavedViewId : String
      + inboxSwipeStartAction : Int
      + inboxSwipeEndAction : Int
    }
  }

  %% ═══════════════════════════════════════════════════════
  %% RELATIONSHIPS
  %% ═══════════════════════════════════════════════════════

  %% Category system
  Category "1" --> "*" Message : categorizes
  Category "1" --> "*" Conversation : labels
  CategoryDao --> Category : CRUD
  ContextKt --> CategoryDao : uses
  ContextKt --> Category : matching logic
  ContextKt --> Message : withAutoCategory()
  ContextKt --> Conversation : refreshCategoryLabel()

  %% Keyword UI
  KeywordManagerKt --> KeywordItem : manages list of
  KeywordItem --* CategoryKeywords : replaces
  AddOrEditCategoryDialog --> KeywordManagerKt : embeds ComposeView
  AddOrEditCategoryDialog --> Category : create / update
  AddOrEditCategoryDialog --> ContextKt : createCategory() / updateCategory()
  SetCategoryDialog --> ContextKt : getAllCategories()
  SetCategoryDialog --> Conversation : sets category string

  %% SavedViews system
  SavedView --> SavedViewType : type
  SavedView --> SavedViewConfig : config
  SavedViewsStore --> SavedView : manages
  SavedViewsStore --> Config : persists to
  MainActivity --> SavedViewsStore : uses
  MainActivity --> SavedView : activeSavedView
  MainActivity --> ConversationAgeHeaderDecoration : decorates list
  Config --> SavedView : savedViewsJson storage

  %% Database
  MessagesDatabase --> CategoryDao : provides
  MessagesDatabase --> Message : stores (with categoryName/categoryId)
  MessagesDatabase --> Conversation : stores (with category)

  %% Activities
  ManageCategoriesActivity --> CategoryAdapter : displays
  ManageCategoriesActivity --> AddOrEditCategoryDialog : launches
  ManageCategoriesActivity --> ContextKt : deleteCategory()
  CategoryAdapter --> Category : binds

  %% Fragment (new two-pane)
  ConversationDetailFragment --> ThreadAdapter : hosts
  MainActivity --> ConversationDetailFragment : two-pane mode

  %% Foldable
  FoldableHelper --> ConversationDetailFragment : layout decisions

  %% Message flow with auto-category
  Message --> Category : categoryId / categoryName ref
  Conversation --> Category : category string label ref

