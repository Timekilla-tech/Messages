  namespace NEW_UI_Compose {
    class KeywordItem {
      <<NEW>>
      + value : String
      + isRegex : Boolean
      + serialize() String
    }
    class CategoryKeywords {
      <<NEW - deprecated, replaced by KeywordItem>>
      - plainWords : List~String~
      - regexPatterns : List~String~
    }
    class KeywordManagerKt {
      <<NEW Composable>>
      + KeywordManager() void
      + SimpleChip() void
      + RegexChip() void
      + KeywordSection() void
      + KeywordChipEditable() void
      + KeywordChip() void
      + KeywordContextMenu() void
      + KeywordEditDialog() void
      - addPlainWords() Boolean
      - addRegexPattern() String?
    }
  }

  namespace NEW_Models {
    class Category {
      <<MODIFIED>>
      + id : Long
      + name : String
      + color : Int
      + icon : String
      + description : String
      + isDefault : Boolean
      + keywords : String
      + keywordIsRegex : Boolean
      %% ── NEW fields ──
      + plainKeywords : String
      + regexPatterns : String
    }
    class SavedView {
      <<NEW>>
      + id : String
      + type : SavedViewType
      + title : String
      + position : Int
      + isEditable : Boolean
      + config : SavedViewConfig
      + iconResName : String?
    }
    class SavedViewConfig {
      <<NEW>>
      + folderId : Long?
      + tags : Set~String~
      + showArchived : Boolean
      + unreadOnly : Boolean
      + pinnedOnly : Boolean
      + matchAllTags : Boolean
    }
    class SavedViewType {
      <<NEW enum>>
      MAIN
      CUSTOM
    }
  }

  namespace NEW_Modified_Models {
    class Message {
      <<MODIFIED>>
      + id : Long
      + body : String
      + threadId : Long
      %% ── NEW fields ──
      + categoryName : String
      + categoryId : Long
    }
    class Conversation {
      <<MODIFIED>>
      + threadId : Long
